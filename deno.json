{
  "tasks": {
    "dev": "deno run -A --unstable-kv npm:vite --host 127.0.0.1",
    "build": "deno run -A --unstable-kv npm:vite build",
    "start": "deno serve -A --unstable-kv --host 127.0.0.1 --port 8000 _fresh/server.js",
    "check": "deno check --unstable-kv main.ts client.ts routes/**/*.tsx islands/**/*.tsx components/**/*.tsx lib/**/*.ts tests/**/*.ts",
    "test": "deno test --unstable-kv --allow-read --allow-write --allow-env",
    "verify": "deno fmt --check && deno lint && deno task check && deno task test && deno task build",
    "fmt": "deno fmt",
    "lint": "deno lint"
  },
  "imports": {
    "@/": "./",
    "@fresh/plugin-vite": "jsr:@fresh/plugin-vite@^1.1.2",
    "@preact/signals": "npm:@preact/signals@^2.5.1",
    "@std/assert": "jsr:@std/assert@^1.0.14",
    "fresh": "jsr:@fresh/core@^2.3.3",
    "fresh/": "jsr:@fresh/core@^2.3.3/",
    "fresh/internal": "https://jsr.io/@fresh/core/2.3.3/src/internals.ts",
    "fresh/internal-dev": "https://jsr.io/@fresh/core/2.3.3/src/internals_dev.ts",
    "fresh/runtime": "https://jsr.io/@fresh/core/2.3.3/src/runtime/shared.ts",
    "fresh/runtime-client": "https://jsr.io/@fresh/core/2.3.3/src/runtime/client/mod.ts",
    "preact": "npm:preact@10.29.2",
    "preact/hooks": "npm:preact@10.29.2/hooks",
    "preact/jsx-dev-runtime": "npm:preact@10.29.2/jsx-dev-runtime",
    "preact/jsx-runtime": "npm:preact@10.29.2/jsx-runtime",
    "ts-fsrs": "npm:ts-fsrs@5.4.1",
    "vite": "npm:vite@^7.1.0"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "jsxImportSourceTypes": "preact"
  },
  "nodeModulesDir": "auto",
  "fmt": {
    "exclude": [
      "_fresh"
    ]
  },
  "lint": {
    "exclude": [
      "_fresh"
    ]
  }
}
